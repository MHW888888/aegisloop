    {
      "name": "alpha_evidence",
      "pattern": "alpha[_\\s-]?evidence\\s*[:=]\\s*true"
    },
    {
      "name": "git_write",
      "pattern": "(^|[;\\n])\\s*git\\s+(commit|push|merge)\\b|(^|[;\\n])\\s*git\\s+add\\s+\\."
