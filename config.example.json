  "denylist": [
    {
      "name": "production_signal",
      "pattern": "production[_\\s-]?signal\\s*[:=]\\s*(true|on)|(\\u63a5\\u5165|\\u4e0a\\u7ebf|\\u542f\\u7528|\\u5f00\\u542f)\\u751f\\u4ea7\\u4fe1\\u53f7"
